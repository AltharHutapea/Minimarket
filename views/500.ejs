<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>500 - Kesalahan Server</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <i class="bi bi-exclamation-octagon display-1 text-danger"></i>
                <h1 class="display-1 fw-bold text-danger">500</h1>
                <p class="lead">Terjadi kesalahan pada server.</p>
                <p class="text-muted"><%= message || 'Silakan coba lagi beberapa saat lagi.' %></p>
                <% if (typeof error !== 'undefined' && error && error.stack) { %>
                    <pre class="text-start bg-light p-3 rounded small text-danger"><%= error.stack %></pre>
                <% } %>
                <a href="/dashboard" class="btn btn-primary mt-3">
                    <i class="bi bi-house-door"></i> Kembali ke Dashboard
                </a>
            </div>
        </div>
    </div>
</body>
</html>
