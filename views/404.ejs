<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>404 - Halaman Tidak Ditemukan</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
</head>
<body>
    <div class="container mt-5">
        <div class="row justify-content-center">
            <div class="col-md-6 text-center">
                <i class="bi bi-signpost-split display-1 text-warning"></i>
                <h1 class="display-1 fw-bold text-warning">404</h1>
                <p class="lead">Halaman yang Anda cari tidak ditemukan.</p>
                <p class="text-muted"><%= message || 'URL yang diminta tidak tersedia di server ini.' %></p>
                <a href="/dashboard" class="btn btn-primary mt-3">
                    <i class="bi bi-house-door"></i> Kembali ke Dashboard
                </a>
            </div>
        </div>
    </div>
</body>
</html>
