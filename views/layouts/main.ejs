<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %> - Minimarket</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <div class="bg-dark text-white" id="sidebar-wrapper" style="min-width: 250px;">
            <div class="sidebar-heading text-center py-4 primary-text fs-4 fw-bold text-uppercase border-bottom">
                <i class="bi bi-shop"></i> Minimarket
            </div>
            <div class="list-group list-group-flush my-3">
                <% if (isLoggedIn) { %>
                    <a href="/dashboard" class="list-group-item list-group-item-action bg-dark text-white">
                        <i class="bi bi-speedometer2"></i> Dashboard
                    </a>
                    <a href="/products" class="list-group-item list-group-item-action bg-dark text-white">
                        <i class="bi bi-box-seam"></i> Produk
                    </a>
                    <a href="/transactions" class="list-group-item list-group-item-action bg-dark text-white">
                        <i class="bi bi-receipt"></i> Transaksi
                    </a>
                    <a href="/reports/low-stock" class="list-group-item list-group-item-action bg-dark text-white">
                        <i class="bi bi-exclamation-triangle"></i> Laporan Stok
                    </a>
                    <% if (user && ['admin', 'manager'].includes(user.role)) { %>
                        <a href="/users" class="list-group-item list-group-item-action bg-dark text-white">
                            <i class="bi bi-people"></i> Manajemen User
                        </a>
                    <% } %>
                    <a href="/logout" class="list-group-item list-group-item-action bg-dark text-danger">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </a>
                <% } %>
            </div>
        </div>

        <!-- Page Content -->
        <div id="page-content-wrapper" class="w-100 d-flex flex-column" style="min-height: 100vh;">
            <%- include('../partials/navbar') %>

            <div class="container-fluid px-4 flex-grow-1">
                <%- body %>
            </div>

            <%- include('../partials/footer') %>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/js/script.js"></script>
</body>
</html>
